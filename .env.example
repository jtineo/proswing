# ══════════════════════════════════════════════════════════
# OctoEmployee — ProSwing Athletic Training
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════

# ── Claude / Anthropic ─────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── GoHighLevel ────────────────────────────────────────────
# Get from: GHL dashboard → Settings → Integrations → API Keys
# Use the AGENCY-level API key (not location-level)
GHL_API_KEY=

# The sub-account Location ID for this client
# Get from: GHL → Sub-account → Settings → Business Profile → Location ID
GHL_LOCATION_ID=

# ── Mindbody ───────────────────────────────────────────────
# Get from: Mindbody → Developer Portal → https://developers.mindbodyonline.com
MINDBODY_API_KEY=

# The numeric Site ID for the client's Mindbody account
# Get from: Mindbody → Account Settings → Site ID (displayed in the URL or account info)
MINDBODY_SITE_ID=

# ── Auth & Security ────────────────────────────────────────
# 64-character hex string — signs session tokens (HMAC-SHA256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# 32-character hex string — HMAC-hashes PINs before storage
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
PIN_STORE_SECRET=

# Protects /api/sync, /api/report, /api/briefing endpoints
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=

# ── Monitoring ─────────────────────────────────────────────
# GHL Contact ID of the agency owner — receives sync failure alerts and anomaly warnings
# Get from: GHL → Contacts → find agency owner → copy the contact ID from the URL
AGENCY_OWNER_CONTACT_ID=
